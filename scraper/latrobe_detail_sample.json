<script>
(function() {
    if (!Array.prototype.intersect){
        Array.prototype.intersect = function(targetArray) {
            return this.filter(value => targetArray.includes(value));
        }
    }
    
    function setDigitalDataAndTrack(key, obj, trackType) {
        console.log('setDigitalDataAndTrack', arguments);
    	const s = window;
    	s.digitalData = s.digitalData || {};
    	if (typeof s.digitalData[key] !== 'undefined') delete s.digitalData[key]
    	s.digitalData[key] = obj;
    	
    	console.log(`digitalData.${key}`, s.digitalData[key]);
    	console.log(`before run _satellite.track('${trackType}')`);
    	if (typeof _satellite === 'undefined') console.log('[setDigitalDataAndTrack] _satellite is undefined')
    	typeof _satellite !== 'undefined' && _satellite.track(trackType);
    	console.log(`after run _satellite.track('${trackType}')`);
    }
    
    // 

    function whenAEMFormAvailable() {
        let resolve;
        const p = new Promise((_resolve, _reject) => {
            resolve = _resolve
        });
        if (typeof guideBridge !== 'undefined') {
            console.debug('guideBridge is already available on page load');
            resolve(guideBridge);
        } else {
            window.addEventListener("bridgeInitializeStart", function(event) {
                console.debug('bridgeInitializeStart() triggered');
                resolve(event.detail.guideBridge);
            });
        }
        
        return p;
    }
    
    let formName, formType;
    
    whenAEMFormAvailable()
    .then((guideBridge) => {
        guideBridge.connect(() => {
            const elemFormContainer = document.querySelector(guideBridge.SELECTOR_FORM_CONTAINER);
            const elemFormWrapper = elemFormContainer.closest('[data-analytics-form-tracking-name]');
            
            if (elemFormWrapper && elemFormWrapper.dataset.analyticsFormTrackingName && elemFormWrapper.dataset.analyticsFormTrackingType) {
                formName = elemFormWrapper.dataset.analyticsFormTrackingName;
                formType = elemFormWrapper.dataset.analyticsFormTrackingType;
                
                let _lastInteractedField = null;
                
                const FIELD_NOT_PRESENT = "field not present";
                const FIELD_NO_VALUE = "field not selected";
                
                
                function _trackFormStart() {
                    if (formType === 'application') {
                        _setApplicationDataAndTrack('Application Start', 'application_track');
                    }
                    else {
                            setDigitalDataAndTrack(
                                'form',
                                {
                                    'formName': formName,
                                    'formType': formType,
                                    'formStep': 'start',
                                },
                                'form_track'
                            );
                    }
                    
                    guideBridge.off("elementFocusChanged", _trackFormStart);
                }
                
                guideBridge.on("elementFocusChanged", _trackFormStart);
                
                // gather available fields
                const availableFields = [];
                // const _properties = Object.getOwnPropertyDescriptors(guideBridge._guide.runtime);
                const _guideRuntime = window.guidelib.runtime;
                const _properties = Object.getOwnPropertyDescriptors(_guideRuntime);
                
                for (var i in _properties) {
                    if (typeof _properties[i].get !== 'function') continue;
                    if (typeof _guideRuntime[i].jsonModel.bindRef === 'undefined') continue;
                    // console.log(i, guideBridge._guide.runtime[i].jsonModel.bindRef);
                    availableFields.push(
                        _guideRuntime[i].jsonModel.bindRef
                    );
                };
                function _flattenRequestData(obj) {
                    let result = {};
                    for (const i in obj) {
                        if ((typeof obj[i]) === 'object' && !Array.isArray(obj[i])) {
                            const temp = _flattenRequestData(obj[i]);
                            for (const j in temp) {
                                result[('/' + i + '/' + j).replace('//', '/')] = temp[j];
                            }
                        } else {
                            result['/' + i] = obj[i];
                        }
                    }
                    return result;
                };
                
                
                
                function _getFormValue(key, obj, availableFields) {
                    if (!availableFields.includes(key)) return FIELD_NOT_PRESENT;
                    return typeof obj[key] !== 'undefined' ? obj[key] : FIELD_NO_VALUE;
                }
                
                function _getFormValues(keys, obj, availableFields) {
                    console.log('_getFormValues', keys, obj);
                    if (!availableFields.intersect(keys).length) return FIELD_NOT_PRESENT;
                    const result = [];
                    for (const i of keys) {
                        if (typeof obj[i] !== 'undefined') {
                            result.push(obj[i]);
                        }
                    }
                    return result.length ? result.join(',') : FIELD_NO_VALUE;
                }
                
                function _formatCoursePreference(course, location) {
                    if (typeof course === 'undefined' || location === 'undefined' || course === FIELD_NOT_PRESENT || location === FIELD_NOT_PRESENT) {
                        return FIELD_NOT_PRESENT;
                    }
                    else if (course == null || location == null || course === FIELD_NO_VALUE || location === FIELD_NO_VALUE) {
                        return FIELD_NO_VALUE;
                    }
                    
                    return course + '###' + location;
                }
                
                function _getApplicationID() {
                    if(_satellite.getVar('applicationID') === undefined || _satellite.getVar('applicationID') === null)
                    {
                        var currentDate = Date.now();
                        var applicantVID = _satellite.getVisitorId().getMarketingCloudVisitorID().slice(0,5);
                        _satellite.setVar('applicationID', currentDate+applicantVID);
                        return currentDate+applicantVID;
                    }
                    else
                    {
                        return _satellite.getVar('applicationID');
                    }
                }
                
                function _getAEMValue(fieldName) {
                    if (guideBridge.resolveNode(fieldName)) {
                        if (guideBridge.resolveNode(fieldName).value) {
                            return guideBridge.resolveNode(fieldName).value;
                        }
                        else {
                            return FIELD_NO_VALUE;
                        }
                    }
                    else {
                        return FIELD_NOT_PRESENT;
                    }
                }
                                
                function _setApplicationDataAndTrack(applicationStep, trackStep) {
                    try {
                        console.log('applicationStep',applicationStep);
                        setDigitalDataAndTrack(
                            'application',
                            {
                                'applicationType': formName,
                                'applicationStep': applicationStep,
                                'applicationId': _getApplicationID(), 
                                'studentId': FIELD_NOT_PRESENT,
                              	'campus': FIELD_NOT_PRESENT, 
                            	'course': FIELD_NOT_PRESENT,
                                'courseYear': FIELD_NOT_PRESENT,
                                'courseSemester': FIELD_NOT_PRESENT,
                                'courseType': FIELD_NOT_PRESENT,
                                'userType': _getAEMValue('current_year_level'),
                                'coursePreference1': _formatCoursePreference(_getAEMValue('course_preference_1_course_search'), _getAEMValue('course_preference_1_campus_search')),
                                'coursePreference2': _formatCoursePreference(_getAEMValue('course_preference_2_course_search'), _getAEMValue('course_preference_2_campus_search')),
                                'coursePreference3': _formatCoursePreference(_getAEMValue('course_preference_3_course_search'), _getAEMValue('course_preference_3_campus_search')),
                                'coursePreference4': _formatCoursePreference(_getAEMValue('course_preference_4_course_search'), _getAEMValue('course_preference_4_campus_search')),
    
                            },
                            trackStep
                        );
                    } catch (e) {
                        console.log(e);
                    }
                }
                
                //console.log('availableFields', availableFields);

                guideBridge.on("submitStart" , (event) => {
                    guideBridge.getData({
                        async:false,
                        success: (guideResultObject) => {
                            _lastInteractedField = null;
                            
                            const submissionData = JSON.parse(guideResultObject.data);
                            const requestData = submissionData.afData.afBoundData.data;
                            const requestDataFlat = _flattenRequestData(requestData);
                            const formDataMap = {
                                enquiryType: FIELD_NOT_PRESENT,
                                campus: _getFormValues( 
                                    [
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Lead_Registration_Common_Elements/Campus_Of_Interest_1',
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Aspire_Year_11_Elements/Campus_Of_Interest_2',
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Aspire_Year_11_Elements/Campus_Of_Interest_3',
                                    ],
                                    requestDataFlat,
                                    availableFields
                                ),
                                residence: FIELD_NOT_PRESENT,
                                studyArea: _getFormValue('/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Lead_Registration_Common_Elements/Area_Of_Interest/Area_Of_Interest_Name', requestDataFlat, availableFields),
                                userType: _getFormValues(
                                    [
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Marketing_Elements/Enquirer_Type',
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Aspire_Year_11_Elements/Current_Year_Level'
                                    ],
                                    requestDataFlat,
                                    availableFields
                                ),
                                citizenship: _getFormValue('/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Lead_Registration_Common_Elements/Country_Of_Citizenship', requestDataFlat, availableFields),
                                course: _getFormValues( 
                                    [
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Lead_Registration_Common_Elements/Course_Name_1',
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Aspire_Year_11_Elements/Course_Name_2',
                                        '/Request/Service_Request/Ask_Marketing_Lead_Interest_Registration/Aspire_Year_11_Elements/Course_Name_3',
                                    ],
                                    requestDataFlat,
                                    availableFields
                                ),
                                studyLevel: FIELD_NOT_PRESENT,
                                userCategory: FIELD_NOT_PRESENT,
                                commencingStudyWithin: FIELD_NOT_PRESENT,
                            };
                            
                            console.log('formDataMap', formDataMap);
                            if (formType === 'application') {
                                _setApplicationDataAndTrack('Application Complete', 'application_track');
                            }
                            else {
                                 setDigitalDataAndTrack(
                                    'form',
                                    {
                                        'formName': formName,
                                        'formType': formType,
                                        'formStep': 'complete',
                                        ...formDataMap
                                    },
                                    'form_track'
                                );
                            }
                        }
                    })
                });
                
                function _trackLastElement(event, payload) {
                    const component = payload.target;
                    //console.log('event', event);
                    //console.log('payload', payload)
                    
                    //Track email address specifically
                    const BR = component.bindRef;
                    if (BR && digitalData.form && BR.includes('/Lead_Registration_Common_Elements/Personal_Email/Email_Address')) {
                        digitalData.form.emailAddress = component.value ? component.value.trim().toLowerCase() : 'field not selected';
                    }
                    
                    _lastInteractedField = {
                        fieldName: component.title || component.name,
                        interactionType: event.type,
                    };
                    console.log('_lastInteractedField', _lastInteractedField)
                }
                
                guideBridge.on("elementValueChanged", _trackLastElement);
                //guideBridge.on("elementFocusChanged", _trackLastElement);
                
                function _trackLastInteractedField() {
                    if (!!_lastInteractedField) {
                        const fieldName = _lastInteractedField.fieldName;
                        _lastInteractedField = null;
                        
                        try {
                            
                        
                        if (formType === 'application') {
                            setDigitalDataAndTrack(
                                'application',
                                {
                                    'applicationType': formName,
                                    'applicationStep': 'Application Start',
                                    'applicationField': fieldName,
                                },
                                'application_abandon_track'
                            );
                        }
                        else {
                            setDigitalDataAndTrack(
                                'form',
                                {
                                    'formName': formName,
                                    'formType': formType,
                                    'formStep': 'start',
                                    'formField': fieldName,
                                },
                                'form_abandon_track'
                            );
                        }
                        }
                        catch (e) {
                            console.log(e);
                        }
                    }
                }
                
                // document.addEventListener("visibilitychange", () => {
                //     if (document.visibilityState === 'hidden' && _lastInteractedField !== null) {
                //         _trackLastInteractedField();
                //     }
                // });
                
                window.addEventListener("beforeunload", () => _trackLastInteractedField());
                
            } else {
                console.warn('AEM form wrapper does not contain required data attributes for analytics.')
            }
        })
    });
    
    // 
    
    function _determineLinkType(elemAnchor) {
        const _finalURL = new URL(elemAnchor.href, location.href)
        
        return _finalURL.host === location.host ? 'Current site' : 'External site'
    }
    
    function extractGlobalKeyLink(elemAnchor, linkPosition) {
        let linkName = elemAnchor.innerText.trim()
        let elemParent
        if ((elemParent = elemAnchor.closest('.mega-menu-item'))) {
            // is mega menu
            linkName = elemParent.closest('.mega-menu-item').previousSibling.innerText.trim() + ` > ${linkName}`
        }
        return  {
            linkName,
            linkType: _determineLinkType(elemAnchor),
            linkPosition,
            linkPage: window.digitalData.page.pageName,
        }
    }
    
    function extractLocalKeyLink(elemAnchor, position) {
        const lineNamePrefix = elemAnchor.dataset.analyticsKeyLinkInteractionTrackingLinkNamePrefix || ''
        return  {
            linkName: (lineNamePrefix.trim() ? (lineNamePrefix.trim() + ': ') : '') + elemAnchor.innerText.trim(),
            linkType: _determineLinkType(elemAnchor),
            linkPosition: position,
            linkPage: window.digitalData.page.pageName,
        }
    }
    
    document.body.addEventListener('click', (e) => {
        const eventTarget = e.target;
    
        if (eventTarget.tagName.toLowerCase() === 'a') {
            //e.stopPropagation();
            //e.preventDefault();
            
            let position = '';
            let isGlobal = false;
            
            switch (true) {
                //case eventTarget.matches('#header .nav-utility a'):
                case eventTarget.matches('#header .nav-universes a'):
                    position = 'Navigation'
                    isGlobal = true
                    break
                case eventTarget.matches('#footer a'):
                    position = 'Footer'
                    isGlobal = true
                    break
                case eventTarget.matches('main#content a[data-component="ds-hero-banner"]:not([data-youtube])'):
                    position = 'Hero'
                    break
                case eventTarget.matches('main#content a[data-component="ds-hero-promo"]:not([data-youtube])'):
                    position = 'Hero promo'
                    break
                case eventTarget.matches('main#content a[data-component="ds-promo"]:not([data-youtube])'):
                    position = 'Promo'
                    break
            }
    
            if (!!position) {
                const keyLinkObj = isGlobal 
                    ? extractGlobalKeyLink(eventTarget, position)
                    : extractLocalKeyLink(eventTarget, position)
                // console.log('keyLinkObj', keyLinkObj)
                setDigitalDataAndTrack('keyLink', keyLinkObj, 'keyLink');
            }
            // return false;
        }
        
    }, true);
})()
</script>

<script>
(function() {

    // let _lastView = null;
    
    function triggerView(viewName) {
        // if (_lastView === viewName) {
        //     console.log(`duplicate call to triggerView(${_lastView})`)
        //     return;
        // }
        if (typeof adobe === 'undefined') console.log('[triggerView] adobe is undefined')
        if (typeof adobe.target === 'undefined') console.log('[triggerView] adobe.target is undefined')
        adobe?.target?.triggerView(viewName)
        
        // _lastView = viewName
        console.log(`after run adobe.target.triggerView('${viewName}')`);
    }
    
    document.body.addEventListener('click', (e) => {
        const eventTarget = e.target;
    
        if (typeof eventTarget.dataset.analyticsViewName !== 'undefined') {
            const viewName = eventTarget.dataset.analyticsViewName || eventTarget.innerText.trim()
            triggerView(viewName)
        }
        
    }, true);
    
    document.body.addEventListener('analyticsviewchanged', (e) => {
        const viewName = e.detail?.viewName 
        if (viewName) {
            triggerView(viewName);
        } else {
            console.log(`viewName is not supplied`)
        }
    });
})()
</script>

