if (h1 && h1.textContent.trim()) { pageTitle = h1.textContent.trim(); }
if (normalisedUrlPath.length) { dtmPageName = dtmPageName.concat( normalisedUrlPath.split('/').slice(0, 3) ); }
if (pageTitle) { if (dtmPageName.length >= 4) { dtmPageName.pop(); } dtmPageName.push(pageTitle); }
dtmPageName = dtmPageName.join(':');
var digitalData = digitalData || {};
digitalData.page = digitalData.page || {};
digitalData.page.pageCategory = digitalData.page.pageCategory || {};
