# Local Postgres credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=courseteer

# Connection string used by the scraper and Next.js ORM.
# For both local development and production, use the Supabase connection string.
# Transaction pooler (port 6543) is recommended for best performance.
# Example: postgresql://postgres.[project_ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# Course level filter for the scraper (UG for undergraduate only)
COURSE_LEVEL_FILTER=UG

# Adminer web UI port (default: 8080)
ADMINER_PORT=8080
