# Local Postgres credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=courseteer

# Connection string used by the scraper and Next.js ORM.
# For local dev this points to the Docker container.
# For production, replace with the Supabase connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/courseteer

# Adminer web UI port (default: 8080)
ADMINER_PORT=8080
